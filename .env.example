# PartFolder 3D — environment variable reference
#
# Copy this file to .env and fill in secrets before first run:
#   cp .env.example .env
#
# .env is gitignored. Never commit real secrets to the repo.
#
# ── LOCAL DEV QUICK START ──
# Full stack with hot reload:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build
# Production stack:
#   docker compose up -d


# ── Database ──────────────────────────────────────────────────────────────────

# Password for the Postgres partfolder3d user.
# Change this to a strong random value before exposing the service.
POSTGRES_PASSWORD=changeme


# ── Application ───────────────────────────────────────────────────────────────

# External port for the nginx reverse proxy.
# The app is available at http://localhost:<APP_PORT> after `docker compose up`.
APP_PORT=8973

# Root directory for app-managed data (DB dumps, config, thumbnails, inbox, logs).
# Maps to /data inside containers. Do NOT point this at a library mount.
DATA_DIR=./data


# ── Backend (overrides config.py defaults) ────────────────────────────────────

# SQLAlchemy async URL — normally set by compose from POSTGRES_PASSWORD above.
# Override here only if you're running an external Postgres.
# DATABASE_URL=postgresql+asyncpg://partfolder3d:changeme@localhost:5432/partfolder3d

# Redis URL — arq job queue broker.
# REDIS_URL=redis://localhost:6379

# Set DEBUG=true to enable SQLAlchemy query logging and FastAPI debug mode.
# DEBUG=false

# Comma-separated CORS origins allowed by the backend.
# Defaults cover the nginx proxy port and the Vite dev server.
# ALLOWED_ORIGINS=http://localhost:8973,http://localhost:5173
