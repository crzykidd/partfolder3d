# PartFolder 3D — environment variable reference
#
# Copy this file to .env and fill in secrets before first run:
#   cp .env.example .env
#
# .env is gitignored. Never commit real secrets to the repo.
#
# ── QUICK START ──
# Production (pulls published images — no building):
#   docker compose up -d
# Dev / build-from-source (hot reload — all services + build):
#   docker compose -f docker-compose.dev.yml up --build
# Migrations run automatically (the backend entrypoint runs `alembic upgrade
# head` on startup) — no manual migration step. The dev stack bind-mounts all
# storage under ./private_data/data/ (postgres, redis, app) so you can inspect
# every file on the host. Then open http://localhost:8973 for the first-run wizard.


# ── Runtime user (NFS / shared-storage ownership) ────────────────────────────
#
# PUID/PGID set the UID:GID that the backend, worker, and frontend containers
# run as (via compose `user:`).  On NFS or shared storage this must match the
# owner of the library mount and /data volume so files land with the right
# ownership.  Run `id -u` / `id -g` on the host to find your values.
# Mounted volumes and library paths must be owned by this UID:GID.
PUID=1000
PGID=1000


# ── Database ──────────────────────────────────────────────────────────────────

# Password for the Postgres partfolder3d user.
# Change this to a strong random value before exposing the service.
# NOTE: the backend and worker fail fast at startup if this is left as the literal
# "changeme" while DEBUG is not true. It's a "don't ship the default" guard, not a
# strength check — any value except "changeme" is accepted. It is interpolated into
# a connection URL, so avoid URL-reserved characters (@ : / # ? %); use letters,
# digits, and - _ . (or URL-encode). Same applies to REDIS_PASSWORD below.
POSTGRES_PASSWORD=changeme


# ── Redis ─────────────────────────────────────────────────────────────────────

# Password for Redis (the arq job-queue broker). Redis runs with --requirepass
# and compose injects this into REDIS_URL for both the backend and worker, so
# the whole app authenticates automatically. Redis is not network-published
# (internal Docker network only), but arq deserializes job bodies — so queue
# write access is code execution in the worker. Change this to a strong random
# value before exposing the service.
REDIS_PASSWORD=changeme


# ── Startup / migration tuning ────────────────────────────────────────────────
# These bound how the backend container's entrypoint waits for Postgres and runs
# `alembic upgrade head` on startup. The defaults are safe; raise them only on a
# slow DB host or for unusually long migrations. All are read by
# backend/docker-entrypoint.sh + backend/app/dbcheck.py + backend/alembic/env.py.
#
# Per-attempt connect timeout (seconds) when probing the DB on startup. Default: 5
# DB_CONNECT_TIMEOUT=5
#
# How long (seconds) startup waits for the DB to accept connections before giving
# up with a clear error (instead of hanging forever). Default: 90
# DB_WAIT_TIMEOUT=90
#
# Max time (ms) a migration will wait to acquire its lock before erroring. Default: 30000
# MIGRATION_LOCK_TIMEOUT_MS=30000
#
# Max runtime (ms) for a single migration statement before it is aborted. Default: 300000
# MIGRATION_STATEMENT_TIMEOUT_MS=300000
#
# Hard wall-clock cap (seconds) on the whole `alembic upgrade head` run; a blocked
# migration errors with a clear message instead of hanging the container. Default: 600
# MIGRATION_TIMEOUT=600


# ── Application ───────────────────────────────────────────────────────────────

# External port for the nginx reverse proxy.
# The app is available at http://localhost:<APP_PORT> after `docker compose up`.
APP_PORT=8973

# ── Optional TLS/HTTPS at nginx (standalone self-hosters; skip this if you
# already terminate TLS upstream with Traefik/Caddy/nginx-proxy-manager) ──
# See docs/tls.md for the full guide. Three TLS_MODE values:
#   off        (default) plain :80 only — today's behavior, unchanged.
#   selfsigned nginx auto-generates a self-signed cert on first start and
#              persists it in the nginx_certs volume (docker-compose.yml).
#              Works immediately; browsers show a trust warning.
#   provided   mount your own real fullchain.pem + privkey.pem into the cert
#              dir (bind-mount example in docker-compose.yml). Missing/empty
#              files make the container fail to start (by design — it will
#              NOT silently fall back to plain HTTP).
# Full automatic Let's Encrypt/ACME issuance is tracked separately (#41).
# TLS_MODE=off

# When TLS is on and this is true, the :80 server 301-redirects every
# request to https://$host$request_uri. Leave false if you want :80 and :443
# to both serve plain content (e.g. for a health check that doesn't do TLS).
# TLS_REDIRECT=false

# Host port mapped to the container's :443 — only relevant when TLS_MODE is
# selfsigned or provided (also uncomment the matching port line in
# docker-compose.yml).
# APP_HTTPS_PORT=8443

# ⚠️ IMPORTANT: whenever TLS_MODE is selfsigned or provided, set
# COOKIE_SECURE=true below — secure session cookies require HTTPS. Leaving
# COOKIE_SECURE=false while serving HTTPS will break login.

# Root directory for app-managed data (DB dumps, config, thumbnails, inbox, logs).
# Maps to /data inside containers. Do NOT point this at a library mount.
DATA_DIR=./data


# ── Backend (overrides config.py defaults) ────────────────────────────────────

# SQLAlchemy async URL — normally set by compose from POSTGRES_PASSWORD above.
# Override here only if you're running an external Postgres.
# DATABASE_URL=postgresql+asyncpg://partfolder3d:changeme@localhost:5432/partfolder3d

# Redis URL — arq job queue broker. Normally set by compose from REDIS_PASSWORD
# above (redis://:<password>@redis:6379/0). Override here only for an external
# Redis; include the password in the URL if that Redis requires auth.
# REDIS_URL=redis://:changeme@localhost:6379/0

# Set DEBUG=true to enable SQLAlchemy query logging and FastAPI debug mode.
# DEBUG=false

# Comma-separated CORS origins allowed by the backend (a JSON array also works).
# Defaults cover the nginx proxy port and the Vite dev server. If the frontend is
# served same-origin through nginx you usually don't need to set this at all.
# ALLOWED_ORIGINS=https://partfolder.example.com,http://localhost:8973


# ── Rendering (Phase 4) ───────────────────────────────────────────────────────

# Resolution (pixels, square) for generated mesh thumbnails.
# Larger values produce sharper images but take more time and disk space.
# Default: 512
# RENDER_RESOLUTION=512

# Headless render backend selection.
# "auto" (default) tries: EGL → OSMesa → VTK (picks the first that works).
# Override with "egl", "osmesa", or "vtk" to force a specific backend.
# In the Docker image, "osmesa" (pyrender + Mesa software GL) is expected to
# work; "vtk" is the most reliable fallback on CPU-only hosts.
# RENDER_BACKEND=auto

# Wall-clock kill timeout (seconds) for a single file's render subprocess.
# Each mesh file is rendered in a fresh spawned process; this is the maximum
# time that process is allowed to run before being SIGTERM'd (then SIGKILL'd).
# Increase for very large/complex meshes. Default: 300 (5 minutes).
# RENDER_TIMEOUT_S=300

# Number of CPU threads the render subprocess may use.
# Sets OMP_NUM_THREADS, LP_NUM_THREADS (llvmpipe/Mesa), and related vars
# so pyrender/OSMesa/VTK stay within the specified thread budget.
# Lower values reduce CPU saturation on shared hosts at the cost of render speed.
# Default: 2
# RENDER_CPU_THREADS=2

# Background-render mode — controls when items are auto-rendered to a thumbnail:
#   all        → render every mesh item (default).
#   no_images  → only render items that have NO images (use a render as a
#                fallback thumbnail; skip items that already have real images).
#   off        → never auto-render (no background rendering at all).
# RENDER_MODE=all


# ── Worker concurrency & resource limits ──────────────────────────────────────
# These bound how hard the background worker hits the host. IMPORTANT on small
# machines: a bulk import floods the job queue, and unbounded processing can pin
# every CPU and exhaust RAM — starving the API and the rest of the box. Start
# small and raise carefully.
#
# How many background jobs run AT ONCE. Higher drains the queue faster but uses
# more CPU/RAM. Rule of thumb ~1 per 2 cores. RISK: too high → the whole machine
# thrashes on a bulk import. Default: 2
# WORKER_MAX_JOBS=2
#
# Max 3D RENDER jobs at once (independent of WORKER_MAX_JOBS). Renders are the
# heaviest job — each loads a mesh + runs a vtk-osmesa subprocess (RENDER_CPU_THREADS
# cores, hundreds of MB RAM). RISK: raising this is the fastest way to OOM a small
# host. Keep at 1 on < ~16 GB RAM. Default: 1
# RENDER_CONCURRENCY=1
#
# Max mesh-ANALYSIS jobs at once. Analysis loads whole meshes into RAM (trimesh).
# RISK: memory pressure on constrained hosts. Default: 2
# ANALYZE_CONCURRENCY=2
#
# Wall-clock kill timeout (seconds) for a single file's analyze subprocess
# (issue #37). Mesh analysis runs in an isolated spawned child; it is
# SIGTERM'd (then SIGKILL'd) after this many seconds. Default: 300
# ANALYZE_TIMEOUT_S=300
#
# Per-child virtual-memory bound (MB) for the analyze subprocess (issue #37),
# enforced via RLIMIT_AS before trimesh/numpy are imported in the child. This
# is what makes the worker SURVIVE a pathologically large mesh: an over-limit
# allocation raises a catchable MemoryError inside the child instead of
# risking the container's cgroup OOM-killer picking the parent worker. Never
# set below 1024 (numpy/trimesh import needs headroom). Default: 4096
# ANALYZE_MEM_LIMIT_MB=4096
#
# Max triangle count for mesh analysis (issue #37). Meshes over this cap are
# skipped (not attempted) and stored as a low-confidence stub result instead
# of a full trimesh load. Default: 2000000
# ANALYZE_MAX_TRIANGLES=2000000
#
# Max uncompressed size (MB) of a 3MF's geometry-XML parts (3D/3dmodel.model +
# 3D/Objects/*.model), read from the ZIP central directory WITHOUT
# decompressing (pre-load guard, issue #37 follow-up). trimesh parses each
# part into an lxml DOM that can balloon ~15-20x the raw XML bytes, so this
# catches an oversized 3MF BEFORE the doomed multi-GB parse instead of after.
# Default: 256
# ANALYZE_MAX_3MF_XML_MB=256
#
# Hard container caps applied in docker-compose (worker service). These are the
# BACKSTOP: even if the concurrency limits above are mis-set, the container is
# confined to this many CPUs and this much RAM (it gets OOM-killed rather than
# taking down the host).
#   WORKER_CPUS      — CPU cores the worker container may use. On a 6-core box,
#                      2 leaves 4 for the API + OS. RISK if too high: worker can
#                      saturate the machine during a bulk import. Default: 2
#   WORKER_MEM_LIMIT — max RAM for the worker container (e.g. 3g, 4g). If exceeded
#                      the container is OOM-killed (a clean, recoverable failure)
#                      instead of the host running out of memory. Default: 3g
# WORKER_CPUS=2
# WORKER_MEM_LIMIT=3g


# ── Resource caps (per-file / per-job limits) ─────────────────────────────────
# Guardrails on how much work a single file or archive can trigger. Defaults are
# sensible for a personal library; raise them only if you routinely handle very
# large models or archives. All are backend config.py settings.
#
# Max total UNCOMPRESSED size (MB) allowed when auto-extracting an uploaded/imported
# ZIP. Extraction aborts above this — a zip-bomb / runaway guard. Default: 2048
# ZIP_MAX_UNCOMPRESSED_MB=2048
#
# Max number of files a single ZIP may extract to. Default: 10000
# ZIP_MAX_FILES=10000
#
# Max mesh file size (MB) the server will render to a thumbnail; larger STL/OBJ/PLY
# are skipped silently (no render). Default: 50
# RENDER_MAX_FILE_MB=50
#
# Max triangle count a mesh may have to be server-rendered; over-cap meshes are
# skipped. Default: 1000000
# RENDER_MAX_TRIANGLES=1000000
#
# Max file size (MB) eligible for the in-browser 3D viewer (sets `preview_3d`);
# larger files show only the static thumbnail. Default: 50
# BROWSER_PREVIEW_MAX_MB=50
#
# SECURITY — admin folder-browser allowlist. The Add-Library "Browse" button
# (GET /api/admin/fs/browse) may only descend into these root paths; any path that
# resolves outside them is rejected (blocks traversal to /, /etc, /proc, …). Keep
# this as tight as possible — set it to only the parent(s) of your real library
# mounts. JSON array or comma-separated. Default: ["/library"]
# FS_BROWSE_ROOTS=["/library"]


# ── Auth / Sessions (Phase 1) ─────────────────────────────────────────────────

# Set to false when running over plain http:// (local dev without TLS).
# MUST be true (the default) in any production or https deployment — INCLUDING
# nginx's own built-in TLS_MODE=selfsigned/provided (see the Application
# section above / docs/tls.md), not just an upstream Traefik/Caddy proxy.
# See docs/decisions.md — "cookie-Secure dev toggle".
COOKIE_SECURE=false

# The instance encryption key is auto-generated at first run into
# DATA_DIR/config/secret.key (mode 0600).  You do NOT need to set this here.
# Keep that file backed up — losing it means re-entering all encrypted secrets.
# See docs/decisions.md — "encryption-key handling".


# ── Libraries ────────────────────────────────────────────────────────────────
#
# Libraries are directories mounted into the container where items are stored.
# You define the mounts in docker-compose.yml (or docker-compose.dev.yml) and
# then register each path in the app on the Libraries admin page (Content section).
#
# Dev stack: ./private_data/data/library is pre-mounted at /library.
# After first login, go to the Libraries admin page (Content section), click
# "Add library", and enter:
#   Name: Main Library   Mount path: /library
#
# Production: add as many library volumes as you need, e.g.:
#   volumes:
#     - /mnt/nas/3dprints:/library/main   # in both backend + worker sections
# Then register /library/main on the Libraries admin page (Content section).
#
# Do NOT point DATA_DIR at a library mount — DATA_DIR is for DB dumps, thumbnails,
# config, inbox, logs, and rendered previews; libraries hold the actual model files.


# ── Import / Inbox (Phase 5) ──────────────────────────────────────────────────

# Directory the inbox scanner watches for new asset folders.
# Drop a folder here and the daily inbox_scan job will detect it and surface
# it in the wizard.  Each direct subdirectory = one pending import.
# INBOX_DIR=/data/inbox

# Minimum seconds since a folder's last modification before it is ingested by
# the scanner.  Prevents picking up folders that are still being written.
# INBOX_MTIME_SETTLE_SECONDS=30

# Timeout (seconds) for URL metadata scrape requests.
# SCRAPE_TIMEOUT=15

# Maximum number of images to collect per URL scrape.
# SCRAPE_MAX_IMAGES=20

# SSRF size caps for user-influenced outbound fetches (streamed + aborted past the cap).
# SCRAPE_IMAGE_MAX_MB bounds each downloaded scraped/AgentQL image; SCRAPE_HTML_MAX_MB bounds
# the scraped page body. Lower them if importers are untrusted.
# SCRAPE_IMAGE_MAX_MB=25
# SCRAPE_HTML_MAX_MB=5


# ── Sharing (Phase 7) ────────────────────────────────────────────────────────

# The default expiry for new share links is NOT an env var — it lives in the DB
# Setting "share_default_expiry_days" (edited in the admin UI). Override per-link
# when minting; set the DB setting to 0 to disable expiry by default.

# HTTP timeout (seconds) for fetching a remote instance's share link
# (used by the instance-to-instance import wizard).
# INSTANCE_IMPORT_TIMEOUT=30


# ── Job retention ─────────────────────────────────────────────────────────────

# Days to keep succeeded job rows before the daily retention cron hard-deletes them.
# Default: 7
# JOB_RETENTION_SUCCEEDED_DAYS=7

# Days to keep failed, cancelled, and superseded job rows before hard-deletion.
# Default: 30
# JOB_RETENTION_FAILED_DAYS=30


# ── Trash / orphaned-file reclamation ─────────────────────────────────────────
#
# The daily orphan_cleanup cron (05:00 UTC) reclaims disk space in two ways.
# BOTH default to SAFE behaviour; read the risk notes before tightening them.

# Days a soft-deleted item folder survives under DATA_DIR/trash before the daily
# orphan_cleanup cron HARD-DELETES it. Item delete moves the folder to
# /data/trash/<ts>-<key>/ (never rm -rf), so this is the grace window before that
# copy is permanently removed.
# RISK: this permanently deletes files. Keep it generous.
# Set to 0 (or a negative value) to DISABLE trash purging entirely — trash will
# then grow forever and you must prune /data/trash by hand.
# Default: 30
# TRASH_RETENTION_DAYS=30

# Whether orphan_cleanup DELETES orphaned files under items' prints/ dirs —
# gcode/photo files left on disk when their PrintRecord was deleted (the DELETE
# endpoint intentionally leaves files behind).
#   false (default) → REPORT ONLY: orphans are logged (count + sample paths +
#                     bytes); nothing is deleted, so you can review first.
#   true            → delete an orphan ONLY if it is unreferenced AND older than
#                     TRASH_RETENTION_DAYS, with per-file logging.
# RISK: true permanently deletes files.
# Default: false
# ORPHAN_PRINTS_DELETE=false
